# Copie ce fichier en .env.local et remplis les valeurs
# depuis la console Firebase : https://console.firebase.google.com

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# PIN Super-Admin pour déverrouillage de ventes (changer en production)
VITE_SUPER_ADMIN_PIN=1234
